  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "heic-to": "^1.5.2",
    "heic2any": "^0.0.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "vercel": "^54.18.6"
  }
}
