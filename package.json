{
  "name": "cantonscene",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "node server.mjs",
    "dev:web": "vite --config web/vite.config.js",
    "build:web": "vite build --config web/vite.config.js",
    "generate:demo-audio": "node scripts/generate_demo_audio.mjs",
    "qa:demo-audio": "node scripts/qa_demo_audio.mjs",
