# Supabase
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.4-mini
PHOTO_UNDERSTANDING_PROVIDER=openai
OPENAI_VISION_MODEL=gpt-5.4-mini
OPENAI_VISION_DETAIL=low
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# AI cost monitoring
# Optional JSON override. Prices are USD per 1M tokens.
# Example:
# {"openai:gpt-5.4-mini":{"inputPer1M":1,"outputPer1M":8},"openai:gpt-4o-mini-tts":{"totalPer1M":0.6},"google:gemini-3.5-flash":{"inputPer1M":0,"outputPer1M":0}}
AI_COST_PRICE_TABLE_JSON=

# App
APP_ENV=local
